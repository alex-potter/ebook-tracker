siness partner and acquaintance"},{"character":"Amos Burton","relationship":"Business partner and acquaintance"},{"character":"Alex Kamal","relationship":"Business partner and acquaintance"}],"recentEvents":"Housed crew while they stayed in Tycho."},{"name":"Becca Orlowski","aliases":["Rebecca","Orlowski"],"importance":"minor","status":"alive","lastSeen":"Chapter: The Last Serenity","currentLocation":"Canterbury","description":"The communications officer aboard the Canterbury.","relationships":[{"character":"Jim Holden","relationship":"Communications Officer"},{"character":"William Orlowski","relationship":"Father"},{"character":"Ava Tukunbo","relationship":"Navigator"},{"character":"Mark Paj","relationship":"Engineer"}],"recentEvents":"Becca sent out a message to the broken ship and informed Ceres about the unexpected detour."},{"name":"Detective Miller","aliases":["Detective","Earth Dog","Joseph Miller","the cop","Miller","Josephus Miller","Cop","James Miller","Joseph"],"importance":"main","status":"alive","lastSeen":"Ceres Station Blues","currentLocation":"Eros","description":"A former detective now focused on finding James Holden and Julie Mao, determined despite personal setbacks.","relationships":[{"character":"James Holden","relationship":"Trying to locate and help"},{"character":"Julie Mao","relationship":"Determined to find her"},{"character":"Shaddid","relationship":"Former captain, now antagonist"},{"character":"Muss","relationship":"Colleague"}],"recentEvents":"Received information about a potential lead for James Holden via terminal communication from his friend Havelock."},{"name":"Amos Burton","aliases":["Amos","Amos 'Tango Down' Burton","Tango Down","Amo","A.B.","Mister Burton","Mr. Burton","Mechanical Genius"],"importance":"main","status":"alive","lastSeen":"Chapter 12","currentLocation":"Tycho","description":"A mechanical genius and the Rocinante's chief mechanic, Amos is loyal and dependable.","relationships":[{"character":"James Holden","relationship":"Captain and close friend"},{"character":"Naomi Nagata","relationship":"Tactical coordinator and close friend"},{"character":"Alex Kamal","relationship":"Navigator and friend"}],"recentEvents":"Engaged the services of an expensive prostitute."},{"name":"Javier Liu","aliases":["Javier"],"importance":"secondary","status":"alive","lastSeen":"Chapter 4","currentLocation":"Distinguished Hyacinth Lounge","description":"A structural engineer from Tycho, now with his grandchildren running his bar the Distinguished Hyacinth Lounge.","relationships":[{"character":"Cassio Ramachandra","relationship":"acquaintance"}],"recentEvents":"Talking with members of the vice and exploitation team in his bar."},{"name":"Kate Liu","aliases":["Kate"],"importance":"secondary","status":"alive","lastSeen":"Chapter 4","currentLocation":"Distinguished Hyacinth Lounge","description":"Fourth generation owner of the Distinguished Hyacinth Lounge.","relationships":[{"character":"Javier Liu","relationship":"grandfather"}],"recentEvents":"Serving drinks to Miller and Havelock."},{"name":"Cassio Ramachandra","aliases":["Ramachandra"],"importance":"main","status":"alive","lastSeen":"Chapter 4","currentLocation":"Distinguished Hyacinth Lounge","description":"Star Helix Security's top officer, working for Amunet, known for his sharp mind and a penchant for using Miller's alias.","relationships":[{"character":"Josephus Miller","relationship":"fellow Star Helix Security agent, co-worker"},{"character":"Yevgeny Cobb","relationship":"fellow homicide officer"},{"character":"Javier Liu","relationship":"acquaintance"}],"recentEvents":"Present in the Distinguished Hyacinth Lounge when the alert came in."},{"name":"Pramod Rao","aliases":["Shaddid","Governor Shaddid"],"importance":"main","status":"alive","lastSeen":"Chapter: Earth Is Pulling Out","currentLocation":"Ceres Station","description":"Strict and unyielding leader of Ceres under United Nations supervision, now overseeing the peaceful transition of governance.","relationships":[{"character":"Muss","relationship":"Detective partner"},{"character":"Miller","relationship":"Head detective"}],"recentEvents":"Declared the transition of governance from Earth to a provisional local government due to Mars' requests."},{"name":"Shirtless","aliases":[],"importance":"minor","status":"unknown","lastSeen":"Unknown","currentLocation":"Station dock","description":"A steroid-pumped Belt rioter.","relationships":[],"recentEvents":"Murdered a woman and was incapacitated by Miller."},{"name":"The Woman","aliases":[],"importance":"minor","status":"dead","lastSeen":"Unknown","currentLocation":"Unknown","description":"Victim of the Belt riot.","relationships":[],"recentEvents":"Murdered by Shirtless during the riot."},{"name":"The OPA Man","aliases":[],"importance":"minor","status":"alive","lastSeen":"Unknown","currentLocation":"Station dock","description":"A supporter of the Outer Planets Alliance involved in the station riot.","relationships":[],"recentEvents":"Challenged Miller's authority during the riot but backed down."},{"name":"Julian","aliases":[],"importance":"main","status":"alive","lastSeen":"A New Home","currentLocation":"Unknown","description":"A friend of Miller's.","relationships":[{"character":"Joseph Miller","relationship":"friend"}],"recentEvents":"Not mentioned in recent events."},{"name":"Theresa Yao","aliases":[],"importance":"secondary","status":"alive","lastSeen":"Chapter title where they last appeared","currentLocation":"Donnager","description":"Captain of the MCRN Donnager, the battleship that is to pick up Holden's crew.","relationships":[{"character":"James Holden","relationship":"target of investigation"}],"recentEvents":"Communicated with the crew of Knight regarding course and advised against further general broadcasts."},{"name":"Ariadne Mao","aliases":["Mama Mao"],"importance":"secondary","status":"alive","lastSeen":"Chapter 7: The Abyss","currentLocation":"Unknown","description":"The mother of Julie Mao and wife of Jules-Pierre Mao, involved in family business and estranged family relations.","relationships":[{"character":"Julie Mao","relationship":"Daughter"},{"character":"Jules-Pierre Mao","relationship":"Husband"}],"recentEvents":"Sent a message to Julie warning her about the safety of the Belt."},{"name":"Jules-Pierre Mao","aliases":["JP Mao"],"importance":"secondary","status":"alive","lastSeen":"Chapter 7: The Abyss","currentLocation":"Unknown","description":"CEO of the Mao-Kwikowski Mercantile and father of Julie Mao, involved in consolidating his business properties.","relationships":[{"character":"Julie Mao","relationship":"Daughter"},{"character":"Ariadne Mao","relationship":"Wife"}],"recentEvents":"Going through a consolidation phase and considering selling the Razorback."},{"name":"Vincent Havelock","aliases":[],"importance":"main","status":"alive","lastSeen":"Ain't No Justice","currentLocation":"Ceres Station","description":"A younger detective with a keen interest in justice and a strong sense of morality.","relationships":[{"character":"Joseph Miller","relationship":"Partner"}],"recentEvents":"Waited for Miller at the station, expressed concern for his well-being."},{"name":"Unidentified OPA Leader","aliases":[],"importance":"minor","status":"alive","lastSeen":"Ain't No Justice","currentLocation":"Unknown","description":"A pock-faced man in a bar who spoke confidently about OPA's operations.","relationships":[{"character":"Joseph Miller","relationship":"Interacted with"}],"recentEvents":"Discussed OPA's political stance with Miller, warned him not to return to the bar."},{"name":"Aleksandr Mahotina","aliases":["Alex","Alexander Kamal"],"importance":"main","status":"alive","lastSeen":"Return Only Changes","currentLocation":"Torpedo Bomber","description":"Former MCRN pilot, the helmsman of the Rocinante, and a close friend to the crew.","relationships":[{"character":"James Holden","relationship":"Captain and superior"},{"character":"Naomi Nagata","relationship":"Crewmate and friend"},{"character":"Fred Johnson","relationship":"Allied leader through OPA"}],"recentEvents":"Turned off the transponder signal of the MCRN gunboat to evade detection. Set a course to the coordinates given to Holden by Fred Johnson."},{"name":"Lopez","importance":"minor","status":"alive","lastSeen":"Chapter: Tug of War","currentLocation":"Unknown","description":"A mariner with the Rocinante, primarily a medic and a pilot.","relationships":[{"character":"James Holden","relationship":"Captain and crew member"}],"recentEvents":"Lopez is not mentioned in this chapter."},{"name":"A marine officer","importance":"minor","status":"alive","lastSeen":"Chapter: Tug of War","currentLocation":"Unknown","description":"A naval intelligence officer on the Donnager who questioned James Holden.","relationships":[{"character":"James Holden","relationship":"Interviewed subject"}],"recentEvents":"The officer questioned Holden and left his quarters during the battle."},{"name":"Dawes","aliases":["Agent Dawes"],"importance":"secondary","status":"alive","lastSeen":"Chapter: Earth Is Pulling Out","currentLocation":"Ceres Station","description":"Station official often in discussions with Shaddid about station affairs and stability.","relationships":[{"character":"Shaddid","relationship":"Station official"},{"character":"Miller","relationship":"Contacts in station affairs"}],"recentEvents":"Was present in Shaddid's office for the announcement of Miller's firing and the new state of affairs."},{"name":"Anderson Dawes","aliases":["none"],"importance":"secondary","status":"alive","lastSeen":"The Butcher of Anderson Station","currentLocation":"Unknown","description":"A member of the Outer Planets Alliance, Dawes is also Miller's informant.","relationships":[{"character":"Miller","relationship":"informant and occasional aide"}],"recentEvents":"Provided Miller with information on the police equipment raid and confirmed the involvement of the Black Cat organization."},{"name":"Hasini","aliases":[],"importance":"minor","status":"alive","lastSeen":"Drunk","currentLocation":"Ceres","description":"Owner of a bar named Blue Frog, helpful and concerned about the well-being of regular patrons like Miller.","relationships":[{"character":"James Miller","relationship":"Bar regular and patron"}],"recentEvents":"Helped a drunk and troubled Miller by taking him home in an electric cart."},{"name":"Julie","aliases":["Julie"],"importance":"minor","status":"alive","lastSeen":"Chapter: Earth Is Pulling Out","currentLocation":"Unknown","description":"Unnamed character mentioned by Miller, likely crucial to Miller's investigations.","relationships":[{"character":"Miller","relationship":"Unknown contact or person of interest"}],"recentEvents":"Milller queried aloud what she might have seen that is worth the conflict."}],"locations":[{"name":"The Scopuli","aliases":["Scopuli"],"arc":"Piracy","description":"A ship that has been attacked and abandoned, located in the belt between planets.","recentEvents":"Jim and Amos investigate the ship and discover a fake distress beacon that led to the discovery of the derelict ship.","relationships":[{"location":"Knight","relationship":"Investigation crew arrives to the site of the distress call from Scopuli"}]},{"name":"Canterbury","aliases":["The Canterbury","Canter"],"arc":"War","description":"A commercial transport ship destroyed in a surprise attack.","recentEvents":"A group of survivors from the destroyed Canterbury have been rescued and are now being transported to safety, but they face new dangers aboard the ship.","relationships":[{"location":"Hangar Bay","relationship":"Part of the Canterbury where the survivors are hiding and trying to escape"}]},{"name":"CA-2216862","arc":"Emergency and Rescue","description":"A charted non-Belt asteroid near which the distressed Scopuli is located.","recentEvents":"The Scopuli is found in the vicinity of this asteroid in distress.","relationships":[{"location":"Scopuli","relationship":"Scopuli is located near it"}]},{"name":"Knight","aliases":["ship"],"arc":"The Protomolecule","description":"A ship belonging to the crew whose fate is entwined with the mysterious protomolecule and its effects.","recentEvents":"Crew received a message from Colonel Johnson, an influential figure in the Outer Planets Alliance, warning them against coercion and offering assistance if they need it.","relationships":[{"location":"Donnager","relationship":"Knight is being pursued by this Martian battlecruiser"},{"location":"Outer Planets Alliance","relationship":"Colonel Johnson offers support from this organization"}]},{"name":"Blue Frog Lounge","arc":"Conflict","description":"An entertainment venue on Ceres where local security officers gather.","recentEvents":"Miller and Havelock initially struggle with their relationship there; Miller later turns the conversation around with help from the bar staff and his colleagues.","relationships":[{"location":"Ceres","relationship":"Part of"}]},{"name":"Distinguished Hyacinth Lounge","arc":"Conflict","description":"A bar frequented by Ceres security personnel, including Star Helix Security.","recentEvents":"Miller and Havelock continue their conversation here, addressing Havelock's concerns and turning it into a more positive interaction.","relationships":[{"location":"Ceres","relationship":"Part of"}]},{"name":"Martian Congressional Republic","arc":"Conflict","description":"The government and military of Mars.","recentEvents":"The stealth ship involved in the destruction of the Canterbury appears to be equipped with technology that bears the serial number of the Martian navy.","relationships":[{"location":"Canterbury","relationship":"The ship's destruction by the stealth ship raised suspicions about involvement with Mars military technology"}]},{"name":"Cantnery Belt","arc":"Conflict","description":"A region in space surrounding Saturn, known for having numerous asteroids and other space debris.","recentEvents":"Six unidentified dark ships are intercepted on a course that will bring them to the Knight near the edge of the Belt.","relationships":[{"location":"Knight","relationship":"The unidentified ships are approaching Knight's location in the Belt."}]},{"name":"Mars","arc":"Politics and Conflict","description":"The fourth planet in the solar system, a major power involved in the conflict with the Belt.","recentEvents":"James Holden and the Canterbury raised concerns about the possibility of war between Mars and the Belt.","relationships":[{"location":"Belt","relationship":"Mars is in conflict with the Belt over resources and political power."}]},{"name":"Luna","arc":"Politics and Conflict","description":"Earth's moon, a key player in the Belt-Mars conflict, and home to the Mao-Kwikowski family's headquarters.","recentEvents":"Julie Mao's mother, Ariadne Mao, sends a message from Luna to Julie about the fate of the Razorback.","relationships":[{"location":"Earth","relationship":"Luna is in close association with Earth, playing a role in the Belt-Mars conflicts."},{"location":"Mars","relationship":"Luna has significant ties and conflicts with Mars over resources and political power."}]},{"name":"Razorback","arc":"Politics and Conflict","description":"A personal boat of Julie Mao, significant due to her father's contemplation of selling it.","recentEvents":"The fate of the Razorback is in question as Julie's parents consider selling it.","relationships":[{"location":"Julie Mao","relationship":"The Razorback is closely associated with Julie Mao, a personal possession with sentimental and logistical value for her."}]},{"name":"Outer Planets Alliance","aliases":["OPA"],"arc":"The Protomolecule","description":"A political body representing the interests of inhabitants of the outer planets, potentially aligned against Mars.","recentEvents":"Colonel Johnson of the OPA reaches out to the Knight crew, urging caution and informing them of potential threats to their freedom.","relationships":[{"location":"Knight","relationship":"Attempted to support the Knight crew against potential coercion"},{"location":"Donnager","relationship":"OPA warns against Martian influence"}]},{"name":"Ceres Station","aliases":["Ceres","Cererean"],"arc":"Conflict","description":"A space station in the asteroid belt populated by miners and settlers","recentEvents":"Ceres experienced several riots and a curfew was imposed to maintain stability amid growing tensions.","relationships":[{"location":"Mars","relationship":"Ceres is caught in the conflict between Mars and Earth"},{"location":"Tycho","relationship":"Ceres residents begin to seek refuge on Tycho"}]},{"name":"SS Donnager","aliases":["MCRN Donnager","Martian battlecruiser","Donnager"],"arc":"Attack on Donnager","description":"A powerful Martian battlecruiser that threatens the crew's freedom.","recentEvents":"The Donnager encounters a group of unidentified ships and engages in a brutal battle with point defense systems and gauss turrets active. The ship is hit by a torpedo, and internal damage is caused.","relationships":[{"location":"Unknown ships","relationship":"Engaged in battle against"},{"location":"Knight","relationship":"Pursuing the Knight ship"},{"location":"Outer Planets Alliance","relationship":"The OPA warns about the influence of this battlecruiser"}]},{"name":"Eros","arc":"Conflict","description":"An asteroid located near Mars","recentEvents":"The mysterious ship Miller is tracking plans a flight to Eros, sparking intrigue and uncertainty.","relationships":[{"location":"Ceres","relationship":"A possible destination for information Miller seeks"},{"location":"Tycho","relationship":"Miller initially plans to travel to Tycho but changes his ticket to Eros"}]},{"name":"Hangar Bay","arc":"War","description":"A part of the Canterbury where spacecraft can be stored and launched.","recentEvents":"Survivors attempt to escape in a commandeered corvette, while facing enemy boarders.","relationships":[{"location":"Canterbury","relationship":"Part of the Canterbury"}]},{"name":"Ganymede","arc":"Conflict","description":"A large moon of Jupiter, significant for its role in interplanetary trade and being a staging point for operations involving Ceres.","recentEvents":"Serves as the destination for the Black Cat freighter carrying stolen police equipment from Ceres.","relationships":[{"location":"Ceres","relationship":"The Black Cat freighter transported stolen police equipment and personnel to Ganymede from Ceres."}]},{"name":"Tachi","arc":"The Donnager Event","description":"A salvaged MCRN gunboat now in Jim Holden's possession.","recentEvents":"Jim Holden and his crew use Tachi to escape the battle and seek refuge from the MCRN.","relationships":[{"location":"MCRN","relationship":"Currently evading"}]},{"name":"Tycho Station","aliases":["Tycho Manufacturing and Engineering Concern"],"arc":"The Expansion","description":"A large orbital station circling a planet, serving as a hub for space travel and commerce.","recentEvents":"The crew is spending time on Tycho to rest and gather information before deciding their next steps.","relationships":[{"location":"Rocinante","relationship":"The crew visits and repairs the ship docked at Tycho"}]},{"name":"Rocinante","aliases":["Roci"],"arc":"The Expansion","description":"The ship the crew is using for their missions, a modified old transport.","recentEvents":"Holden comforts himself by spending time in the cockpit, connecting with the silent ship.","relationships":[{"location":"Tycho Station","relationship":"Docked at Tycho Station"}]},{"name":"Triton","arc":"Conflict","description":"A moon of Neptune with a deep astronomy lab occupied by OPA supporters","recentEvents":"Triton's astronomy lab was taken over and used to broadcast sensitive information about Mars, escalating tensions.","relationships":[{"location":"Mars","relationship":"Broadcasting details of Mars' military positions and activities"},{"location":"Ceres","relationship":"Increased unrest on Ceres due to Triton's actions"}]},{"name":"Triton Astronomy Lab","arc":"Conflict","description":"A facility on Triton taken over by a band of OPA supporters for broadcasting","recentEvents":"Used to broadcast the locations of all Martian ships and high-definition images of Mars, causing further tension.","relationships":[{"location":"Triton","relationship":"Contained within Triton and a hot spot of conflict"},{"location":"Mars","relationship":"Causing significant information leaks about Mars' military positions"}]}],"arcs":[{"name":"Detective Miller's OPA Investigation","status":"active","characters":["Detective Miller","Anderson Dawes"],"summary":"Detective Miller has agreed to drop the Mao investigation but retains some level of commitment or interest in finding her through his agreement with Anderson Dawes."},{"name":"Surviving the Donnager incident","status":"active","characters":["Jim Holden","Naomi Nagata","Alex Kamal"],"summary":"The team has escaped the Donnager and is now seeking assistance from Fred Johnson, potentially revealing a new level of OPA capabilities."},{"name":"Finding Julie","status":"active","characters":["Josephus Miller"],"summary":"Miller is frustrated with the loss of his case on Julie, recognizing it as a special and personal matter rather than just a professional case."},{"name":"Miller's Professional Decline","status":"active","characters":["Josephus Miller","Muss"],"summary":"Miller experiences a personal low, feeling that his career is at a downturn and that he's been assigned challenging cases as a form of punishment or due to perceived underperformance."},{"name":"Rocinante's Redemption","status":"active","characters":["Holden","Amos","Naomi","Alex"],"summary":"The crew of the newly christened Rocinante prepares to seek their future under Fred's guidance at Tycho Station."},{"name":"Astronaut Detective's Investigation","status":"active","characters":["Miller"],"summary":"Miller's investigation into Julie's in