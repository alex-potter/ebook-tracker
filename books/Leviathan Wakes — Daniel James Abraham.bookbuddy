us situations.","relationships":[{"character":"Jim Holden","relationship":"Captain"},{"character":"Amos Burton","relationship":"Chief Engineer"},{"character":"Ava Tukunbo","relationship":"Navigator"}],"recentEvents":"Mark had his arm injured while shifting ice, and the ship needed to respond to an emergency signal despite being fully loaded."},{"name":"Naomi Nagata","aliases":["Naomi","First Officer","Nomi","Navcom","Navigation & Communication","no alias","A.N.","Doc","Dr. Nagata","Tyco","Mr. Johnson","Tycho Manager","Fred","Fred Johnson","Comms","Chief Medical Officer"],"importance":"secondary","status":"alive","lastSeen":"Scopuli Report","currentLocation":"Eros Station","description":"The chief medical officer and second-in-command of the Rocinante, a tactical genius and expert in medicine.","relationships":[{"character":"James Holden","relationship":"Captain, leader"},{"character":"Amos Burton","relationship":"Crewmate"},{"character":"Alex Kamal","relationship":"Crewmate"},{"character":"Josephus Miller","relationship":"Investigative partner"}],"recentEvents":"Discusses the potential for radiation shelters and essential personnel handling emergencies."},{"name":"Becca Orlowski","aliases":["Rebecca","Orlowski"],"importance":"minor","status":"alive","lastSeen":"Chapter: The Last Serenity","currentLocation":"Canterbury","description":"The communications officer aboard the Canterbury.","relationships":[{"character":"Jim Holden","relationship":"Communications Officer"},{"character":"William Orlowski","relationship":"Father"},{"character":"Ava Tukunbo","relationship":"Navigator"},{"character":"Mark Paj","relationship":"Engineer"}],"recentEvents":"Becca sent out a message to the broken ship and informed Ceres about the unexpected detour."},{"name":"Amos Burton","aliases":["Amos","Amos 'Tango Down' Burton","Tango Down","Amo","A.B.","Mister Burton","Mr. Burton","Mechanical Genius","Chief","Chief Engineer","The Mechanic","Mr. Fix-It"],"importance":"main","status":"alive","l