{
  "name": "bookbuddy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "build:capacitor": "cross-env NEXT_PUBLIC_CAPACITOR=true node scripts/mobile-build.js",
    "build:pwa-export": "node scripts/mobile-build.js",
    "cap:sync": "npm run build:capacitor && npx cap sync",
    "cap:android": "npm run build:capacitor && npx cap sync && npx cap open android",
    "build:pwa": "cross-env NEXT_PUBLIC_BASE_PATH=/bookbuddy npm run build:pwa-export",
    "deploy:gh-pages": "npm run build:pwa && npx gh-pages -d out",
    "pwa:assets": "node scripts/generate-pwa-assets.js",
    "pwa:assets:check": "node scripts/generate-pwa-assets.js && git diff --exit-code public/icons public/manifest.json",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@ducanh2912/next-pwa": "^10.2.9",
    "claude": "^0.1.1",
    "cross-env": "^7.0.3",
    "framer-motion": "^12.38.0",
    "jszip": "^3.10.1",
    "next": "^14.2.0",
    "potrace": "^2.1.8",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "undici": "^7.22.0",
    "vtracer": "^1.0.8",
    "workbox-window": "^7.4.0"
  },
  "lint-staged": {
    "public/icon.svg": [
      "node scripts/generate-pwa-assets.js",
      "git add public/icons public/manifest.json"
    ]
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "postcss": "^8",
    "pwa-asset-generator": "^6.4.0",
    "tailwindcss": "^3",
    "typescript": "^5"
  }
}
