{
  "name": "bookbuddy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "build:mobile": "node scripts/mobile-build.js",
    "cap:sync": "npm run build:mobile && npx cap sync",
    "cap:android": "npm run build:mobile && npx cap sync && npx cap open android",
    "build:pwa": "cross-env NEXT_PUBLIC_BASE_PATH=/bookbuddy npm run build:mobile",
    "deploy:gh-pages": "npm run build:pwa && npx gh-pages -d out"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "cross-env": "^7.0.3",
    "jszip": "^3.10.1",
    "next": "^14.2.0",
    "potrace": "^2.1.8",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "undici": "^7.22.0",
    "vtracer": "^1.0.8"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "postcss": "^8",
    "tailwindcss": "^3",
    "typescript": "^5"
  }
}
